# Copy to .env.local and fill in values.

# Clerk — https://dashboard.clerk.com (JWT template "supabase" for RLS)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM — Kimi (Moonshot) for cover letters (OpenAI-compatible API)
MOONSHOT_API_KEY=

# Optional: third-party job search
JSEARCH_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (optional)
RESEND_API_KEY=
RESEND_FROM=noreply@example.com
RESEND_FROM_WAITLIST=JobFill <hello@jobfill.co>
RESEND_FROM_UPDATES=JobFill <updates@jobfill.co>

# Playwright worker (CLI or APPLY_TRIGGER_ON_POST)
PLAYWRIGHT_HEADLESS=true
# Default timeout for Playwright locator/page actions (ms). Min 5000, max 120000. Default 30000.
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=30000

# Dev: set to 1 to fire apply worker after POST /api/apply (Node runtime only)
APPLY_TRIGGER_ON_POST=
# Worker CLI: process one job then exit
WORKER_ONCE=
