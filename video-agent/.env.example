MUAPI_API_KEY=
MOONSHOT_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
NOTIFY_EMAIL=

# TikTok — TikTokApi cannot upload; use Playwright + saved login JSON.
# Generate once locally: python -m playwright codegen https://www.tiktok.com --save-storage=tiktok-state.json
TIKTOK_STORAGE_STATE_PATH=
TIKTOK_SKIP=0
TIKTOK_MS_TOKEN=
# legacy alias (not used for upload)
TIKTOK_SESSION_ID=

# Instagram
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SKIP=0

# YouTube Data API v3 (OAuth refresh flow)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_SKIP=0

# Reddit — create a "script" app at https://www.reddit.com/prefs/apps
# Subreddit must allow native video; bot account needs permission to post there.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=JobFillVideoAgent/1.0
# Auth: either refresh token (recommended) OR username + password
REDDIT_REFRESH_TOKEN=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Target subreddit name only, e.g. jobsearch or r/jobsearch
REDDIT_SUBREDDIT=
REDDIT_SKIP=0
# Optional: REDDIT_SEND_REPLIES=0 (default) inbox off; REDDIT_SEND_REPLIES=1 for comment notifications
# Optional: REDDIT_UPLOAD_TIMEOUT=600 (seconds)

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Railway / scheduler: use America/New_York so 09:00 == 9am ET
TZ=America/New_York

# RUN_STARTUP_JOB=1 runs pipeline once on boot (default 1). Set 0 to only use cron times.
RUN_STARTUP_JOB=1
